APP_NAME=zuplae-python-starter
APP_DESCRIPTION='zuplae-python-starter com uma base moderna, rápida e padronizada — focada em FastAPI + Poetry, lint/format, testes, Docker e CI.'
APP_VERSION=0.0.1
API_PREFIX_V1=/api/v1
LOG_LEVEL=INFO
ENABLE_UVICORN_ACCESS_LOGS=true
API_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]